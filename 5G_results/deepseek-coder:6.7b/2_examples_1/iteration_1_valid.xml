<beginning>
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="10" property_id="50" type_property="ATTACK" 
    description="High rate of PDU session establishment and release operations.">
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
      <event value="COMPUTE" event_id="1" 
             description="NGAP/NAS PDU Session Establishment Request detected."
             boolean_expression="(ngap.procedure_code == 1)"/>
      <event value="COMPUTE" event_id="2" 
             description="PFCP session establishment message detected."
             boolean_expression="(pfcp.message_type == 1)"/>
    </operator>
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
      <event value="COMPUTE" event_id="3" 
             description="NGAP/NAS PDU Session Release Request detected."
             boolean_expression="(ngap.procedure_code == 2)"/>
      <event value="COMPUTE" event_id="4"
             description="PFCP session deletion message detected."
             boolean_expression="(pfcp.message_type == 2)"/>
    </operator>
  </property>
</beginning>