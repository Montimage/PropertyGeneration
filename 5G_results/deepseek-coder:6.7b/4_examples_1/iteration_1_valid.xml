<beginning>
  <!-- Property 100: Detection for excessive user-plane traffic -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="100" type_property="ATTACK" description="Detection of Excessive User-Plane Traffic">
    <event value="COMPUTE" event_id="1" 
           description="Exceeding defined throughput or packet-rate thresholds over a time window."
           boolean_expression="(gtpu.packet_rate > #define_threshold(10)) OR (ip.packet_loss > 5%)"/>
    <event value="COMPUTE" event_id="2" 
           description="Persistent traffic saturation correlates with increased packet loss or latency."
           boolean_expression="(#avg(gtpu.packet_rate) > #define_threshold(10)) AND (ip.latency > 50ms)"/>
  </property>
</beginning>