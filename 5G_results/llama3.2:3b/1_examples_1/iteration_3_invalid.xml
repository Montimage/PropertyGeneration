<beginning>
  <!-- Property 65: Detection of abnormal UE registration surges -->

  <property value="THEN" delay_units="s" delay_min="10" delay_max="30" property_id="65" type_property="ATTACK"
    description="Detection of abnormal UE registration surges">
      <event value="COMPUTE" event_id="1" 
             description="UE RegistrationRequest message received over N2 interface"
             boolean_expression="(nas.procedure_code == 'REGISTRATION_REQUEST')"/>
      <event value="COMPUTE" event_id="2" 
             description="Repeated UE RegistrationRequest messages detected within time window"
             boolean_expression="(nas.pdu_present && nas.ran_ue_id != null) && (nas.procedure_code == 'REGISTRATION_REQUEST' || (nas.procedure_code == 'REGISTRATION_ACCEPT'))">
        <embedded_functions>
          #check_thresholds(10, 30)
        </embedded_functions>
      </event>
      <event value="COMPUTE" event_id="3" 
             description="Registration attempt completion"
             boolean_expression="(nas.pdu_present && nas.procedure_code == 'REGISTRATION_ACCEPT' || (nas.procedure_code == 'REGISTRATION_COMPLETE'))">
        <embedded_functions>
          #check_thresholds(10, 30)
        </embedded_functions>
      </event>
    </property>
</beginning>