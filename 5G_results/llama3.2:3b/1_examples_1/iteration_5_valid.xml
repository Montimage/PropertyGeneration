<beginning>
    <!-- Property 1: AMF UE Registration Surge Detection -->

    <property value="THEN" delay_units="ms" delay_min="-1" delay_max="0" property_id="1" type_property="ATTACK"
        description="AMF UE registration surge detection">
            <event value="COMPUTE" event_id="3" 
                description="UE registration attempt"
                boolean_expression="(nas.protocol = 'NAS' and nas.message_type = 'RegistrationRequest')"/>
            <event value="COMPUTE" event_id="4" 
                description="Repeat RegistrationRequest within time window"
                boolean_expression="(count(nas.protocol = 'NAS' and nas.message_type = 'RegistrationRequest') > threshold)"/>
    </property>
</beginning>