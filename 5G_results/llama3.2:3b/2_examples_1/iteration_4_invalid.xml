<beginning>
    <property value="THEN" delay_units="ms" delay_min="-1+" delay_max="10" property_id="X" type_property="ATTACK"
        description="5G core must maintain stable session management behavior and detect abnormal PDU session establishment and release churn">
        <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
            <event value="COMPUTE" event_id="1" 
                description="UE initiates NAS PDU Session Establishment Request message"
                boolean_expression="(ngap.msg_type == 5)"/>
            <event value="COMPUTE" event_id="2" 
                description="UE initiates NAS PDU Session Release Request message"
                boolean_expression="((ngap.msg_type == 6)&amp;&amp;(ip.src == ip.src.1))"/>
        </operator>
        <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
            <event value="COMPUTE" event_id="3" 
                description="Session setup request without sustained session duration"
                boolean_expression="((tcp.flags == 1)&amp;&amp;((ip.src == ip.src.1)&amp;&amp;(ip.dst == ip.dst.1)))"/>
        </operator>
    </property>
</beginning>