<beginning>
  <!-- Property 101: Abnormal PDU session establishment and release churn -->
  <property value="THEN" delay_units="ms" delay_min="-1" delay_max="0" property_id="101" type_property="ATTACK"
           description="Abnormal PDU session establishment and release churn">
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10"/>
    <!-- Context -->
    <event value="COMPUTE" event_id="5" 
          description="Session management behavior of SMF and UPF."
          boolean_expression="(ngap.pdu_present &amp;&amp; ngap.amf_ue_id &amp;&amp; (nas.msg_type == 1))">
      <!-- Trigger -->
      <event value="COMPUTE" event_id="6"
            description="Repeated NAS PDU Session Establishment Request and PDU Session Release Request messages."
            boolean_expression="(nas.msg_type == 3 | nas.msg_type == 7) &amp;&amp; ((ngap.pdu_present &amp;&amp; ngap.amf_ue_id))">
    </operator>
  </property>
</beginning>