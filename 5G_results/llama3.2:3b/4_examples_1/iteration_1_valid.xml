<beginning>
    <!-- Property 35: Detection of abnormal user-plane traffic patterns -->
    <property value="THEN" delay_units="s" delay_min="30" delay_max="180" property_id="35" type_property="ATTACK"
        description="Detection of abnormal user-plane traffic patterns originating from UEs after successful PDU session establishment">
        <event value="COMPUTE" event_id="3" 
               description="Abnormal traffic pattern (exceeds threshold)"
               boolean_expression="(#gtpu_packet_rate > 1000 OR #gtpu_byte_volume > 1000000)"/>
        <event value="COMPUTE" event_id="4" 
               description="UE with multiple active sessions"
               boolean_expression="(#amf_ue_id IN (1,2)) AND (#ran_ue_id IN (3,4))"/>
        <event value="COMPUTE" event_id="5" 
               description="Session modification or teardown event"
               boolean_expression="(pfcp.session_modification OR pfcp.session_teardown)"/>
</property>
</beginning>