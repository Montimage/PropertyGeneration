<beginning>
<!-- Property 52: This rule detects inconsistencies between observed GTP-U packets and the tunnel state established by the SMF.
Ref: https://www.ietf.org/rfc/8019.txt -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="52" type_property="SECURITY_RULE"
          description="Inconsistent GTP-U packet">
      <event value="COMPUTE" event_id="3" 
             description="GTP-U packet with unknown TEID"
             boolean_expression="((gtpu.pdu_type != gtpu_TEID) &amp;&amp; (gtpu.teid == 0))"/>
      <event value="COMPUTE" event_id="4" 
             description="GTP-U packet with stale TEID"
             boolean_expression="((gtpu.pdu_type != gtpu_TEID) &amp;&amp; ((gtpu.teid > gtpu.last_seen_teid)))"/>
      <event value="COMPUTE" event_id="5" 
             description="GTP-U packet with inconsistent payload"
             boolean_expression="((gtpu.payload_length != meta.packet_len) &amp;&amp; (gtpu.pdu_type == 'U' ))"/>
</property>
</beginning>