<beginning>
  <!-- Property ID: 101 - Abnormal UE Registration Surge -->
  <property value="THEN" delay_units="ms" delay_min="-1" delay_max="0" property_id="101"
            type_property="SECURITY_RULE" description="Abnormal surge of UE registrations">
    <event value="COMPUTE" event_id="1" description="RegistrationRequest received">
      <boolean_expression>(ngap.pdu_present &amp;&amp; ngap.procedure_code == 'InitialUEMessage' &amp;&amp;
                              ngap.pdu.presence_of_uplinkNasTransport &amp;&amp;
                              nas.message.type == ' RegistrationRequest')</boolean_expression>
    </event>

    <operator value="AND">
      <event value="COMPUTE" event_id="2" description="Abnormal registration rate threshold exceeded">
        <boolean_expression>(mmt_array_last_index('trace', 1) &amp;&amp;
                                mmt_array_count('trace', 'ngap.amf_ue_id') &gt;= threshold)</boolean_expression>
      </event>

      <embedded_functions>
        void on_load() {
          // Load threshold value from configuration
          threshold = load_threshold_from_config();
        }

        void on_unload() {}
      </embedded_functions>
    </operator>
  </property>
</beginning>