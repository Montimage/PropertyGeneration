<beginning>
  <!-- Property 101: Invalid GTP-U Tunnel Usage -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="0" property_id="101" type_property="SECURITY_RULE" description="Invalid GTP-U Tunnel Usage">
    <event value="COMPUTE" event_id="1" description="GTP-U packet received with unknown or stale TEID">
      <boolean_expression>
        ((gtpu.teid &lt;&gt; 0) &amp;&amp;
         !(pfcp.session_established &amp;&amp;
           (gtpu.teid == pfcp.allocated_teid)) &amp;&amp;
         !(pfcp.session_modified &amp;&amp;
           (gtpu.teid == pfcp.new_allocated_teid)))
      </boolean_expression>
    </event>

    <event value="COMPUTE" event_id="2" description="User-plane traffic persists after PFCP session deletion">
      <boolean_expression>
        ((gtpu.teid &lt;&gt; 0) &amp;&amp;
         pfcp.session_deleted &amp;&amp;
         gtpu.teid == pfcp.deallocated_teid)
      </boolean_expression>
    </event>

    <if_satisfied>generate_alert(gtpu.teid, 'N3', timestamp(), inconsistency_with_pfcp_state)</if_satisfied>
  </property>
</beginning>