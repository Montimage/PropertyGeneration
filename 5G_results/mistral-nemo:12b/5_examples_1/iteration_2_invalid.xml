<beginning>
  <!-- Property 101: UPF must forward user-plane traffic only through valid and active GTP-U tunnels -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="101"
            type_property="SECURITY_RULE" description="GTP-U Tunnel Validation">
    <event value="COMPUTE" event_id="101-1"
           description="GTP-U packet received on N3 with unknown TEID">
      <boolean_expression>(
        (gtpu.s_teid != 0) &amp;&amp;
        (!pfcp.session_exists(gtpu.s_teid)) &amp;&amp;
        pfcp.session_state != 'deleted'
      )</boolean_expression>
    </event>
    <event value="COMPUTE" event_id="101-2"
           description="GTP-U packet received on N3 with stale TEID">
      <boolean_expression>(
        (gtpu.s_teid != 0) &amp;&amp;
        (pfcp.session_exists(gtpu.s_teid)) &amp;&amp;
        pfcp.session_state == 'inactive'
      )</boolean_expression>
    </event>
    <event value="COMPUTE" event_id="101-3"
           description="GTP-U packet received on N3 with inconsistent TEID">
      <boolean_expression>(
        (gtpu.s_teid != 0) &amp;&amp;
        (pfcp.session_exists(gtpu.s_teid)) &amp;&amp;
        pfcp.session_state == 'active' &amp;&amp;
        gtpu.s_teid != pfcp.active_session(gtpu.gtp_header.sequence_number).s_teid
      )</boolean_expression>
    </event>
    <event value="COMPUTE" event_id="101-4"
           description="User-plane traffic persists after PFCP session deletion">
      <boolean_expression>(
        gtpu.s_teid != 0 &amp;&amp;
        pfcp.session_state == 'deleted' &amp;&amp;
        gtpu.timestamp > pfcp.session_deletion_time(gtpu.s_teid)
      )</boolean_expression>
    </event>
    <if_satisfied>alert("GTP-U Tunnel Inconsistency", "Invalid TEID: %d, Interface: N3, Timestamp: %llu", gtpu.s_teid, gtpu.timestamp)</if_satisfied>
  </property>
</beginning>