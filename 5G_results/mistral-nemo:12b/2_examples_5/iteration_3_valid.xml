<beginning>
  <!-- Property 101: Excessive PDU Session Establishment/Release Churn -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="0" property_id="101" type_property="SECURITY_RULE"
            description="Excessive PDU Session Establishment/Release Churn">
    <!-- Event: NGAP PDU Session Establishment Request -->
    <event value="COMPUTE" event_id="1" description="NGAP PDU Session Establishment Request"
           boolean_expression="(ngap.procedure_code == 5)"/>

    <!-- Event: NGAP PDU Session Release Request -->
    <event value="COMPUTE" event_id="2" description="NGAP PDU Session Release Request"
           boolean_expression="(ngap.procedure_code == 6)"/>

    <!-- Event: PFCP Session Establishment Request -->
    <event value="COMPUTE" event_id="3" description="PFCP Session Establishment Request"
           boolean_expression="(pfcp.message_type == 14)"/>

    <!-- Event: PFCP Session Deletion Request -->
    <event value="COMPUTE" event_id="4" description="PFCP Session Deletion Request"
           boolean_expression="(pfcp.message_type == 20)"/>
  </property>
</beginning>