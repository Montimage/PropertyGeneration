<beginning>
  <!-- Property 101: UPF User-Plane Traffic Anomaly Detection -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0"
    property_id="101" type_property="SECURITY_RULE"
    description="Detects abnormal traffic patterns from UE(s) causing data-plane saturation">
    <event value="COMPUTE" event_id="1"
      description="GTP-U packet rate exceeds threshold"
      boolean_expression="(gtpu.packet_rate > #{gtpu_packet_rate_threshold})"/>
    <event value="COMPUTE" event_id="2"
      description="Sustained high GTP-U traffic volume"
      boolean_expression="(#{gtpu_traffic_volume_window_start} AND
                           (gtpu.byte_volume - #{gtpu_byte_volume_window_start}) > #{gtpu_traffic_volume_threshold})"/>
    <event value="COMPUTE" event_id="3"
      description="High packet loss on N6 interface"
      boolean_expression="(ip.packet_loss > #{ip_packet_loss_threshold})"/>
  </property>
</beginning>