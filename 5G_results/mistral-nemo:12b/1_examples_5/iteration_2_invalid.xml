<beginning>
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="123" type_property="SECURITY_RULE" description="Detect abnormal surges of UE registration signaling">
  <event value="COMPUTE" event_id="1" description="Normal registration procedure started">
    <boolean_expression>(ngap.message_type == 'InitialUEMessage' &amp;&amp; nas.registration_request_present)</boolean_expression>
  </event>
  <event value="COMPUTE" event_id="2" delay_min="-5000" description="Abnormal surge detected">
    <boolean_expression>((meta.packet_count(ngap.amf_ue_id) &gt;= @abnormal_threshold &amp;&amp; ngap.message_type == 'InitialUEMessage') |
                         (meta.packet_count(nas.registration_request_present) &gt;= @abnormal_threshold &amp;&amp; nas.registration_request_present))</boolean_expression>
  </event>
</property>

<embedded_functions><![CDATA[
#include "mmt_lib.h"

void on_load(){
    mmt_set_var("abnormal_threshold", 10, MMT_VAR_TYPE_INT);
}

]]></embedded_functions>
</beginning>