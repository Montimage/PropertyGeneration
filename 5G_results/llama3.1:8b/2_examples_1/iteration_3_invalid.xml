<beginning>
  <!-- Property 123: High-rate PDU session establishment and release churn -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="10" property_id="123" type_property="SECURITY_RULE" 
    description="High-rate PDU session establishment and release churn">
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
      <!-- Context: NAS PDU Session Establishment Request -->
      <event value="COMPUTE" event_id="1" 
             description="NAS PDU Session Establishment Request"
             boolean_expression="(ngap.procedure_code == 5) & (nas.pdu_present == 1) & ((amf_ue_id != amf_ue_id.1) | (ran_ue_id != ran_ue_id.1))"/>
      <!-- Trigger: NAS PDU Session Release Request -->
      <event value="COMPUTE" event_id="2"
             description="NAS PDU Session Release Request"
             boolean_expression="(ngap.procedure_code == 5) & (nas.pdu_present == 0) & ((amf_ue_id != amf_ue_id.1) | (ran_ue_id != ran_ue_id.1))"/>
      <!-- Rate limiting condition: High rate of PDU session establishment and release operations -->
      <event value="COMPUTE" event_id="3"
             description="High rate of PDU session establishment and release operations"
             boolean_expression="(count(nas.pdu_present == 1) > 10) & (count(nas.pdu_present == 0) > 5) & ((timestamp - prev_timestamp) < 1000)"/>
    </operator>
  </property>
</beginning>