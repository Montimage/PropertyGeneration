<beginning>
  <!-- Property ID: Session Churn Detection -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="10" property_id="123" type_property="SECURITY_RULE" 
    description="Session churn detection for stable session management behavior.">
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
      <!-- Event 1: NAS PDU Session Establishment Request -->
      <event value="COMPUTE" event_id="1" 
             description="NAS PDU Session Establishment Request message observed."
             boolean_expression="(ngap.procedure_code == 'CreateSession') & (nas.pdu_present == true)"/>
      
      <!-- Event 2: NAS PDU Session Release Request -->
      <event value="COMPUTE" event_id="2" 
             description="NAS PDU Session Release Request message observed."
             boolean_expression="(ngap.procedure_code == 'DeleteSession') & (nas.pdu_present == true)"/>
    </operator>
    
    <!-- Trigger: High-frequency create/delete cycles over short time windows -->
    <event value="COMPUTE" event_id="3" 
           description="Temporal pattern of repeated session setup requests without sustained session duration."
           boolean_expression="(COUNT(ngap.procedure_code == 'CreateSession') > 5) & (TIME_WINDOW('10s', ngap.timestamp))"/>
    
    <!-- Trigger: Rate of PDU session establishment and release operations exceeds defined thresholds within a time window -->
    <event value="COMPUTE" event_id="4" 
           description="Rate of PDU session establishment and release operations exceeds defined thresholds within a time window."
           boolean_expression="(RATE(ngap.procedure_code == 'CreateSession') > 10) & (TIME_WINDOW('1m', ngap.timestamp))"/>
    
    <!-- Reactive Function: Generate alert summarizing the session churn rate, affected UE contexts, involved interfaces, and corresponding NAS and PFCP message types. -->
    <if_satisfied>em_generate_alert(affected_ue_contexts, involved_interfaces, nas_message_types, pfcp_message_types)</if_satisfied>
  </property>
</beginning>