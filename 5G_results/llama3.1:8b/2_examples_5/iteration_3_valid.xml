<beginning>
  <!-- Property ID: 67 -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="10" property_id="67" type_property="ATTACK"
    description="Probable excessive PDU session establishment and release">
    <!-- Operator for context trigger -->
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="5">
      <event value="COMPUTE" event_id="1"
             description="NGAP NAS PDU Session Establishment Request message"
             boolean_expression="(ngap.protocol_name == 'NAS' &amp;&amp; ngap.procedure_code == 1)"/>
    </operator>
    <!-- Operator for trigger -->
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="5">
      <event value="COMPUTE" event_id="2"
             description="NGAP NAS PDU Session Release Request message"
             boolean_expression="(ngap.protocol_name == 'NAS' &amp;&amp; ngap.procedure_code == 2)"/>
    </operator>
    <!-- Operator for temporal pattern -->
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="10">
      <event value="COMPUTE" event_id="3"
             description="High-frequency create/delete cycles over short time window"
             boolean_expression="(ngap.procedure_code == 1 &amp;&amp; ngap.procedure_code.1 == 2)"/>
    </operator>
  </property>
</beginning>