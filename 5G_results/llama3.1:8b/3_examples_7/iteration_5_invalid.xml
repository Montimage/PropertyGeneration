<beginning>
  <!-- Property: Forwarding NAS security mode COMPLETE that answers to NAS security mode COMMAND -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="100" property_id="91" type_property="ATTACK"
            description="NAS security mode complete messages with the same NAS-SQN, possible replay attack">
    <!-- Event 1: NAS Security mode COMPLETE -->
    <event event_id="1" description="NAS Security mode COMPLETE" boolean_expression="(nas_5g.security_type == 4)"/>
    <!-- Event 2: NAS Security mode COMPLETE msg, coming from the same UE but with different payload -->
    <event event_id="2" description="NAS Security mode COMPLETE msg, coming from the same UE but with different payload"
           boolean_expression="((ngap.amf_ue_id == ngap.amf_ue_id.1)&amp;&amp;(nas_5g.message_authentication_code == nas_5g.message_authentication_code.1)&amp;&amp;(nas_5g.security_type == 4)&amp;&amp;(nas_5g.sequence_number == nas_5g.sequence_number.1)&amp;&amp;(ip.src == ip.src.1)&amp;&amp;(ip.dst == ip.dst.1)&amp;&amp;(nas_5g.p_data != nas_5g.p_data.1)&amp;&amp;(sctp_data.data_tsn != sctp_data.data_tsn.1))"/>
  </property>
</beginning>