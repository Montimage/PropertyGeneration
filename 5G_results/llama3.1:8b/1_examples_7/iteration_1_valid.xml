<beginning>
    <!-- Property 91: Abnormal surge of registration requests from the same UE. -->
    <property value="THEN" delay_units="ms" delay_min="0" delay_max="100" property_id="91" type_property="ATTACK" 
        description="Abnormal surge of registration requests from the same UE." >
        <!-- Event 1: Registration request with new NAS-SQN and AMF-UE-ID -->
        <event value="COMPUTE" event_id="1" 
            description="Registration request with new NAS-SQN and AMF-UE-ID"
            boolean_expression="(nas_5g.security_type == 0)"/>
        
        <!-- Event 2: Registration request with same NAS-SQN, AMF-UE-ID, and IP addresses within a short time frame -->
        <event value="COMPUTE" event_id="2" 
            description="Registration request with same NAS-SQN, AMF-UE-ID, and IP addresses"
            boolean_expression="((nas_5g.security_type == 0)&amp;&amp;(nas_5g.sequence_number == nas_5g.sequence_number.1)&amp;&amp;(ngap.amf_ue_id == ngap.amf_ue_id.1)&amp;&amp;(ip.src == ip.src.1)&amp;&amp;(ip.dst == ip.dst.1)&amp;&amp;((nas_5g.message_authentication_code != nas_5g.message_authentication_code.1)||
                                        (nas_5g.sequence_number != nas_5g.sequence_number.1))&amp;&amp;(#isWithinTimeWindow(nas_5g.timestamp, 100)))"/>
        
        <!-- Event 3: Count of registration requests with same NAS-SQN, AMF-UE-ID, and IP addresses within a short time frame -->
        <event value="COMPUTE" event_id="3" 
            description="Count of registration requests with same NAS-SQN, AMF-UE-ID, and IP addresses"
            boolean_expression="((nas_5g.security_type == 0)&amp;&amp;(nas_5g.sequence_number == nas_5g.sequence_number.1)&amp;&amp;(ngap.amf_ue_id == ngap.amf_ue_id.1)&amp;&amp;(ip.src == ip.src.1)&amp;&amp;(ip.dst == ip.dst.1)&amp;&amp;((nas_5g.message_authentication_code != nas_5g.message_authentication_code.1)||
                                        (nas_5g.sequence_number != nas_5g.sequence_number.1))&amp;&amp;(#isWithinTimeWindow(nas_5g.timestamp, 100))&amp;&amp;(nas_5g.registration_request_count == 3))"/>
    </property>
</beginning>