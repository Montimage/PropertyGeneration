<beginning>
  <!-- Property: Inconsistency between observed GTP-U packets and tunnel state -->
  <property value="THEN" delay_units="ms" delay_min="0+" delay_max="100" property_id="43" type_property="SECURITY_RULE"
    description="Inconsistency between observed GTP-U packets and tunnel state">
    <operator value="THEN" delay_units="ms" delay_min="0+" delay_max="50">
      <!-- Event 1: Unknown or stale TEID in GTP-U packet -->
      <event value="COMPUTE" event_id="1"
             description="Unknown or stale TEID in GTP-U packet"
             boolean_expression="(gtpu.teid != smf.pfcp_state.teid)"/>
      <!-- Event 2: Traffic not corresponding to any active PDU session -->
      <event value="COMPUTE" event_id="2"
             description="Traffic not corresponding to any active PDU session"
             boolean_expression="(gtpu.traffic_direction != pcfp_state.pdu_session_status)"/>
    </operator>
    <!-- Event 3: Mismatch between observed TEIDs and active PFCP session state -->
    <event value="COMPUTE" event_id="3"
           description="Mismatch between observed TEIDs and active PFCP session state"
           boolean_expression="(gtpu.teid != pcfp_state.active_sessions)"/>
  </property>
</beginning>