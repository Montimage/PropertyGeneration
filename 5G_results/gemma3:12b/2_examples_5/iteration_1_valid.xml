<beginning>
<!-- Property 100: Detect high-frequency PDU session establishment/release churn -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="500" property_id="100" type_property="ATTACK" 
          description="Detect high-frequency PDU session establishment/release churn (N4 interface PFCP)">
    <operator value="THEN" delay_units="ms" delay_min="0" delay_max="100">
      <event value="COMPUTE" event_id="1"
             description="PFCP Session Establishment Request"
             boolean_expression="((pfcp.message_type == 2)&amp;&amp;(pfcp.direction == 1))"/>
      <event value="COMPUTE" event_id="2"
             description="PFCP Session Release Request"
             boolean_expression="((pfcp.message_type == 2)&amp;&amp;(pfcp.direction == 2))"/>
    </operator>
    <operator value="THEN" delay_units="ms" delay_min="0" delay_max="500">
        <event value="COMPUTE" event_id="3"
               description="Second PFCP Session Establishment Request within a short time window"
               boolean_expression="((pfcp.message_type == 2)&amp;&amp;(pfcp.direction == 1)&amp;&amp;(meta.timestamp - event_timestamp.1 &lt; 2000))"/>
        <event value="COMPUTE" event_id="4"
               description="PFCP Session Release Request following a Session Establishment Request"
               boolean_expression="((pfcp.message_type == 2)&amp;&amp;(pfcp.direction == 2)&amp;&amp;((meta.timestamp - event_timestamp.1 &lt; 1000)))"/>
    </operator>
</property>
</beginning>