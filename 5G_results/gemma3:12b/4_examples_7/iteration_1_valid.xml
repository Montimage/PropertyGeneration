<beginning>
<!-- Property 99: Detect GTP Sequence Number Anomalies -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="100" property_id="99" type_property="ATTACK"
    description="GTP message with unusual sequence number (potential attack or misconfiguration).">
    <event event_id="1" value="COMPUTE"
           description="GTP message"
           boolean_expression="(gtp.version &gt; 0)"/>
    <event event_id="2" value="COMPUTE"
           description="Unusual GTP sequence number (e.g., very large or repeating)"
           boolean_expression="(gtp.sequence_number &gt; 65535 OR gtp.sequence_number &lt; 10 OR (gtp.sequence_number mod 10 == 0))"/>
</property>
</beginning>