<beginning>
<!-- Property 1: Excessive GTP-U traffic from a UE -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="1" type_property="ATTACK"
    description="Detects excessive GTP-U traffic from a UE, potentially indicating a data-plane saturation issue.">
    <event value="COMPUTE" event_id="1"
           description="High GTP-U packet rate from a UE."
           boolean_expression="(gtpu.packet_rate > 1000)"/>  <!-- Adjust threshold as needed -->
    <event value="COMPUTE" event_id="2"
           description="High GTP-U byte volume from a UE."
           boolean_expression="(gtpu.byte_volume > 1000000)"/> <!-- Adjust threshold as needed -->
    <event value="COMPUTE" event_id="3"
           description="Sustained high GTP-U traffic over time"
           boolean_expression="(gtpu.packet_rate > 500 &amp;&amp; gtpu.byte_volume > 500000)"/>
</property>
</beginning>