<beginning>
<!-- Property 98:  Uncommon HTTP Header Data Exfiltration -->
<!-- This rule detects the use of the X-Custom-Data header in POST requests,
     potentially indicating an attempt to exfiltrate data. -->

<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="98" type_property="EVASION"
    description="Detection of uncommon HTTP header X-Custom-Data in POST requests.">
    <event value="COMPUTE" event_id="1"
        description="HTTP POST request with X-Custom-Data header."
        boolean_expression="(http.method == 4 &amp;&amp; (http.header_name == 'X-Custom-Data'))"/>
    <event value="COMPUTE" event_id="2"
        description="Print source and destination IP addresses."
        boolean_expression="(ip.src != ip.dst)"/>
</property>
</beginning>