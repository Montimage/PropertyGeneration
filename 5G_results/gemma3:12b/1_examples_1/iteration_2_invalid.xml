<beginning>
  <!-- Property 1: Excessive Registration Requests -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="1" type_property="ATTACK"
             description="Excessive Registration Requests">
    <event value="COMPUTE" event_id="1"
           description="RegistrationRequest messages exceeding threshold"
           boolean_expression="count(ngap.message_type == 'InitialUEMessage' AND ngap.procedure_code == 'InitialUEMessage') > 10 WITHIN 5000"/>
    <event value="COMPUTE" event_id="2"
           description="Log affected identifiers">
           boolean_expression="true"/>
  </property>

  <!-- Property 2: Incomplete Registration Procedure -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="2" type_property="ATTACK"
             description="Incomplete Registration Procedure">
    <event value="COMPUTE" event_id="1"
           description="No AuthenticationResponse after RegistrationRequest">
           boolean_expression="count(ngap.message_type == 'InitialUEMessage' AND ngap.procedure_code == 'InitialUEMessage') > 0 AND count(ngap.message_type == 'UplinkNASTransport' AND ngap.procedure_code == 'AuthenticationResponse') == 0 WITHIN 2000"/>
    <event value="COMPUTE" event_id="2"
           description="Log affected identifiers">
           boolean_expression="true"/>
    </event>
  </property>
</beginning>