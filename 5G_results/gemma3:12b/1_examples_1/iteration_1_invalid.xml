<beginning>
<!-- Property 1: Excessive Registration Request Rate -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="1" type_property="ATTACK"
    description="Excessive Registration Request Rate - Potential DoS">
    <event value="COMPUTE" event_id="1"
           description="Check for excessive RegistrationRequest messages within a time window"
           boolean_expression="count(ngap.procedure_code == 10 && ngap.message_type == 1) > 5 within 10s"/>
    <event value="COMPUTE" event_id="2"
           description="Log affected UE and gNB identifiers"
           boolean_expression="ngap.amf_ue_id != '' && ngap.ran_ue_id != ''"/>
</property>

<!-- Property 2: Repeated Registration Attempts without Completion -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="2" type_property="ATTACK"
    description="Repeated Registration Attempts without Completion">
    <event value="COMPUTE" event_id="3"
           description="Check for repeated RegistrationRequest messages without a corresponding RegistrationComplete"
           boolean_expression="count(ngap.procedure_code == 10 && ngap.message_type == 1) > 3 within 5s without ngap.message_type == 15"/>
    <event value="COMPUTE" event_id="4"
           description="Log affected UE and gNB identifiers"
           boolean_expression="ngap.amf_ue_id != '' && ngap.ran_ue_id != ''"/>
</property>

</beginning>