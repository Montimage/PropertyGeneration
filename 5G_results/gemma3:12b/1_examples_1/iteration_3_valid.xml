<beginning>
  <!-- Property: Excessive UE Registration Requests -->
  <property value="THEN" delay_units="ms" delay_min="0" delay_max="0" property_id="1" type_property="ATTACK" description="Excessive UE Registration Requests">
    <event value="COMPUTE" event_id="1" description="Number of RegistrationRequest messages exceeds threshold" boolean_expression="(count(ngap.procedure_code == 11) &gt; 5)"/>
    <event value="COMPUTE" event_id="2" description="Check for incomplete registration procedure" boolean_expression="(count(ngap.procedure_code == 11) &gt; 0 &amp;&amp; count(ngap.procedure_code == 13) == 0)"/>
  </property>
</beginning>