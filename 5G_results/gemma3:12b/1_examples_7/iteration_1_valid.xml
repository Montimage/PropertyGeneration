<beginning>
<!-- Property 100: Detect repeated NAS security mode COMMAND messages from the same UE within a short timeframe, potentially indicating a replay attack or misconfiguration. -->
<property value="THEN" delay_units="ms" delay_min="0" delay_max="200" property_id="100" type_property="ATTACK"
    description="Repeated NAS security mode COMMAND messages from the same UE within a short timeframe.">
    <event value="COMPUTE" event_id="1"
           description="NAS security mode COMMAND message"
           boolean_expression="(nas_5g.security_type == 1)"/>
    <event value="COMPUTE" event_id="2"
            description="NAS security mode COMMAND message from same UE within a short timeframe"
            boolean_expression="((ngap.amf_ue_id == ngap.amf_ue_id.1)&amp;&amp;(nas_5g.security_type == 1)&amp;&amp;(ip.src == ip.src.1)&amp;&amp;(ip.dst == ip.dst.1)&amp;&amp;(sctp_data.data_tsn == sctp_data.data_tsn.1))"/>
</property>
</beginning>